{
  "name": "cnxh-chapter6-chat-api",
  "version": "1.0.0",
  "description": "Chatbot API Chương 6 - Vấn đề dân tộc và tôn giáo (CNXH khoa học)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:ngrok": "docker compose --profile ngrok up -d",
    "ngrok": "powershell -ExecutionPolicy Bypass -File scripts/start-ngrok.ps1",
    "ngrok:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-ngrok.ps1",
    "ngrok:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-ngrok.ps1"
  },
  "keywords": ["chatbot", "ollama", "express"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
