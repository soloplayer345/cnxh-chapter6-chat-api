PORT=5000
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3.5:0.8b

# Docker Compose tu set OLLAMA_URL=http://ollama:11434/api/generate
# Chay: docker compose up -d --build

# Ngrok (tu chon mot trong hai cach)
# Cach 1 - ngrok tren may host: bun run ngrok (sau khi setup authtoken)
# Cach 2 - ngrok trong Docker: them dong duoi vao file .env roi chay docker:ngrok
# NGROK_AUTHTOKEN=your_token_from_https://dashboard.ngrok.com/get-started/your-authtoken
